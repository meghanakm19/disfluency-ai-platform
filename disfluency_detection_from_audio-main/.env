# Environment Configuration for Stuttering Disfluency Detection System

# Flask Settings
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here-change-in-production

# CUDA/GPU Settings (set to empty for CPU only)
CUDA_VISIBLE_DEVICES=

# Database Settings
DATABASE_NAME=analysis.db

# File Upload Settings
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=uploads/audio
RESULTS_FOLDER=results

# API Settings
API_TIMEOUT=300
